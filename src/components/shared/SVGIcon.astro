---
/**
 * SVGIcon.astro — Inline SVG icon component
 *
 * Renders semantic inline SVGs. No external icon library dependency.
 * Each icon is a <svg> with aria-hidden so screen readers skip decorative icons.
 * For meaningful interactive icons (e.g., nav toggle), pass ariaLabel.
 *
 * Props:
 *   name:     Icon identifier (maps to SVG path data)
 *   size:     Width/height in px (default: 24)
 *   ariaLabel: If set, icon becomes accessible with this label
 *   class:    Additional CSS classes
 */

interface Props {
  name: string;
  size?: number;
  ariaLabel?: string;
  class?: string;
}

const { name, size = 24, ariaLabel, class: className = "" } = Astro.props;

/* ─── SVG viewBox is always 24×24 for consistency ─── */
const svgAttrs: Record<string, string> = {
  xmlns: "http://www.w3.org/2000/svg",
  width: String(size),
  height: String(size),
  viewBox: "0 0 24 24",
  fill: "none",
  stroke: "currentColor",
  "stroke-width": "2",
  "stroke-linecap": "round",
  "stroke-linejoin": "round",
};
if (ariaLabel) {
  svgAttrs["role"] = "img";
  svgAttrs["aria-label"] = ariaLabel;
} else {
  svgAttrs["aria-hidden"] = "true";
}
if (className) svgAttrs["class"] = className;
---

